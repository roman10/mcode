{
  "name": "mcode",
  "version": "0.2.1",
  "description": "Desktop IDE for managing multiple autonomous Claude Code sessions",
  "author": "Feipeng Liu with Claude Code and mcode",
  "license": "Apache-2.0",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "build": "electron-vite build",
    "build:mac": "npm run build && electron-builder --mac",
    "build:mac:signed": "bash scripts/build-signed.sh",
    "package": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run --config vitest.unit.config.mts",
    "test:unit": "vitest run --config vitest.unit.config.mts",
    "test:mcp": "vitest run --config vitest.config.mts",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/"
  },
  "dependencies": {
    "@codemirror/merge": "^6.12.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@vscode/ripgrep": "^1.15.9",
    "better-sqlite3": "^12.8.0",
    "electron-log": "^5.4.0",
    "electron-updater": "^6.8.3",
    "fast-glob": "^3.3.3",
    "node-pty": "^1.1.0",
    "yaml": "^2.8.3"
  },
  "build": {
    "appId": "com.mcode.app",
    "asarUnpack": [
      "node_modules/@vscode/ripgrep/bin/**"
    ],
    "productName": "mcode",
    "publish": {
      "provider": "github",
      "owner": "roman10",
      "repo": "mcode"
    },
    "files": [
      "out/**/*",
      "!node_modules/**/*.{md,ts,map,txt,yml,yaml}",
      "!node_modules/**/{test,tests,__tests__,docs,example,examples}/**"
    ],
    "afterSign": "scripts/notarize.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": "Developer ID Application",
      "notarize": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "@codemirror/language-data": "^6.5.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^9.39.4",
    "@leeoniya/ufuzzy": "^1.0.19",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@replit/codemirror-vim": "^6.3.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@uiw/react-codemirror": "^4.25.8",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "cmdk": "^1.1.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-mosaic-component": "^7.0.0-beta0",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
